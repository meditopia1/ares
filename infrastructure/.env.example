# Self-Hosted Supabase Environment Variables
# Copy this file to .env and fill in your values

############
# Secrets
# Generate with: openssl rand -base64 32
############
POSTGRES_PASSWORD=your-super-secret-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=your-anon-key-generated-with-supabase-cli
SERVICE_ROLE_KEY=your-service-role-key-generated-with-supabase-cli

############
# Database
# For local dev: use 'db' (Docker service name)
# For production: use Cloud SQL private IP
############
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=supabase
POSTGRES_USER=postgres

############
# API URLs
############
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

############
# Auth
############
SITE_URL=http://localhost:3001
ADDITIONAL_REDIRECT_URLS=http://localhost:3001/*
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false

############
# Email (SMTP)
############
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@day1health.co.za
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=admin@day1health.co.za

############
# Storage
############
STORAGE_BACKEND=file
# For production with GCS:
# STORAGE_BACKEND=gcs
# GCS_BUCKET=day1health-prod-member-documents
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

############
# PostgREST
############
PGRST_DB_SCHEMA=public,storage,graphql_public
PGRST_DB_ANON_ROLE=anon
PGRST_JWT_SECRET=${JWT_SECRET}

############
# Studio (Dashboard)
############
STUDIO_PORT=3000
